# 修改 ansible-vault 默认编辑器为nano
# echo 'export EDITOR=nano' >> ~/.bashrc
# source ~/.bashrc

# deploy/secrets.yml.example
# 使用前：
#   cp deploy/secrets.yml.example deploy/secrets.yml
#   填写真实值后执行加密：
#   ansible-vault encrypt deploy/secrets.yml --ask-vault-pass
#
# 之后每次部署：
#   ansible-playbook deploy/deploy_agent.yml --ask-vault-pass
#
# 查看/编辑已加密文件：
#   ansible-vault view deploy/secrets.yml --ask-vault-pass
#   ansible-vault edit deploy/secrets.yml --ask-vault-pass

discord_bot_token: "YOUR_BOT_TOKEN"
gemini_api_key:    "YOUR_GEMINI_API_KEY"
